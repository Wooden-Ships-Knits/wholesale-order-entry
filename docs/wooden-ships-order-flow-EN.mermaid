%%{init: {"theme":"base", "themeVariables": {"primaryColor":"#f6efe6","primaryBorderColor":"#b5651d","lineColor":"#8a6d3b","fontSize":"14px"}}}%%
flowchart TD

%% ================= ACTORS / SYSTEMS =================
subgraph SF["☁️ Salesforce (API)"]
  direction TB
  SF_PROD["Product2 + PricebookEntry<br/>(style, color, price)"]
  SF_ACC["Account / Contact<br/>(buyer data)"]
end

subgraph GCP["🖥️ GCP VM - Backend (Node.js + Express)"]
  direction TB
  API["REST API"]
  PDF["Generate Order PDF"]
end

DB[("🗄️ PostgreSQL<br/>store order")]
MAIL["📧 Email to Admin<br/>(PDF attachment)"]

%% ================= FRONTEND FLOW =================
START([Buyer opens website]) --> SEASON["Select collection / season code<br/>e.g. FALL 2026 - F26"]

SEASON --> REQ_PROD["Frontend requests products<br/>for selected season"]
REQ_PROD --> API
API -->|"query by season"| SF_PROD
SF_PROD -->|"styles + price + color"| API
API --> SHOW_PROD["Show product table<br/>CODE#, STYLE, COLOR, X/S, S/M, M/L, $"]

%% ---- Buyer lookup / autofill ----
SHOW_PROD --> BUYER_IN["Buyer enters email / account ID"]
BUYER_IN --> API2["API searches account"]
API2 --> SF_ACC
SF_ACC -->|"matching account candidates"| API2
API2 --> MATCH{"Account found?"}
MATCH -->|"Yes - multiple"| PICK["Show dropdown<br/>pick the correct account"]
MATCH -->|"Yes - single"| AUTOFILL
MATCH -->|"No"| MANUAL["Enter buyer data manually"]
PICK --> AUTOFILL["Autofill Bill To / Ship To<br/>Buyer, Tel, Resale Tax ID"]
MANUAL --> QTY
AUTOFILL --> QTY

%% ---- Order entry ----
QTY["Enter qty per size (X/S, S/M, M/L)"] --> CALC["Auto-calculate:<br/>TTL QTY, TTL $ per row, Grand Total"]
CALC --> VALID{"Meets order minimum?<br/>18 pcs total • 4 pcs/style<br/>2 pcs/SKU • no pre-pack"}
VALID -->|"No"| ERR["Show error message<br/>highlight problem rows"]
ERR --> QTY

VALID -->|"Yes"| DETAILS["Complete other fields:<br/>Ship window, Part Ship Y/N,<br/>Order date, Tax exemption cert"]
DETAILS --> PAY["Enter payment (credit card):<br/>CC#, Name on card, Exp, CVV"]
PAY --> SIGN["Buyer signature + date<br/>+ accept Terms & Conditions"]
SIGN --> SUBMIT(["SUBMIT ORDER"])

%% ================= BACKEND PROCESS =================
SUBMIT --> API
API --> SAVE["Save order to database<br/>⚠️ WITHOUT storing card number"]
SAVE --> DB
SAVE --> PDF
PDF -->|"PDF with order summary<br/>+ CC details for manual processing"| MAIL
PDF --> CONFIRM["Show confirmation page<br/>to buyer"]
MAIL --> DONE([Done - admin processes order])
CONFIRM --> DONE

%% ================= STYLES =================
classDef ext fill:#f3e2cf,stroke:#b5651d,stroke-width:1.5px,color:#5a3b13;
classDef store fill:#e7f0e7,stroke:#4b7a4b,stroke-width:1.5px,color:#274427;
classDef decision fill:#fdf6e3,stroke:#c9a227,stroke-width:1.5px,color:#6b5a12;
classDef submit fill:#b5651d,stroke:#7a430f,stroke-width:2px,color:#ffffff;
classDef warn fill:#fbe4e4,stroke:#b5651d,color:#7a1f1f;

class SF_PROD,SF_ACC,MAIL ext;
class DB store;
class MATCH,VALID decision;
class SUBMIT,SEASON submit;
class SAVE,ERR warn;
