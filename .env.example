# Server
PORT=8080
CORS_ORIGIN=https://order.wooden-ships.com

# Salesforce (username + password + security token auth)
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
SALESFORCE_DOMAIN=login
# 'login' for production, 'test' for a sandbox

# No price book id needed: wholesale price books are resolved per season by
# name ("<season> Wholesale") — see docs/architecture.md §3.2 and
# backend/app/salesforce/mapping.py.

# PostgreSQL (used by docker-compose to provision the db container and to
# compose the in-network DATABASE_URL for the backend)
POSTGRES_USER=woodenships
POSTGRES_PASSWORD=
POSTGRES_DB=woodenships

# For local (non-Docker) development only — inside compose this is overridden:
# DATABASE_URL=postgresql+psycopg://woodenships:<password>@localhost:5432/woodenships

# PDF output directory inside the backend container (Phase 4)
PDF_OUTPUT_DIR=/output/orders

# Nearby-stockist conflict check (GET /api/accounts/nearby).
# Server-side Google key for the Distance Matrix API — NOT the browser key in
# frontend/.env. Create a separate key, IP-restrict it to the VM, and enable
# only the Distance Matrix API. Leave empty to run in straight-line mode.
GOOGLE_MAPS_SERVER_API_KEY=
# Drive-time threshold: neighbors closer than this many minutes = conflict.
CONFLICT_MAX_MINUTES=20

# Email — DEFERRED (2026-07-14 decision: v1 stops at PDF output).
# Kept for the future follow-up phase:
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# ADMIN_EMAIL=orders@wooden-ships.com
